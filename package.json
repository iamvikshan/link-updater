{
  "name": "links-updater",
  "private": true,
  "description": "Automatically updates repository links/keywords and optionally creates PRs",
  "version": "1.3.0",
  "main": "src/index.ts",
  "scripts": {
    "s": "bun src/index.ts",
    "build": "rimraf dist && ncc build src/index.ts -o dist",
    "prepare": "test -d .git && husky || true",
    "f": "oxfmt --write .",
    "f:check": "oxfmt --check .",
    "lint:fix": "oxlint --fix .",
    "lint": "oxlint .",
    "types": "tsgo --noEmit",
    "check": "bun lint && bun types",
    "bs": "mkdir -p scripts && curl -sL https://raw.githubusercontent.com/iamvikshan/.github/main/scripts/bootstrap.sh > scripts/bootstrap.sh && chmod +x scripts/bootstrap.sh && scripts/bootstrap.sh",
    "upd": "sudo apt update && sudo apt upgrade -y && bun upgrade && bun update --latest && bun i && bun f"
  },
  "keywords": [
    "github",
    "actions",
    "links",
    "automation"
  ],
  "author": "vikshan",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1",
    "js-yaml": "^5.2.1"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "@vercel/ncc": "^0.44.1",
    "axios": "^1.18.1",
    "bun-types": "^1.3.14",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "conventional-changelog-gitmoji": "^0.2.5",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.59.0",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.8",
    "semantic-release-gitmoji": "^1.6.9",
    "ts-node": "^10.9.2",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.24.0"
  }
}
